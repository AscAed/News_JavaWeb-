# Security Configuration
# Copy this file to .env and change the values before running docker-compose up

# MySQL Database Configuration
MYSQL_ROOT_PASSWORD=your_secure_mysql_root_password_here
MYSQL_USER=your_secure_mysql_user_here
MYSQL_PASSWORD=your_secure_mysql_password_here

# MinIO Storage Configuration
MINIO_ROOT_USER=your_secure_minio_user_here
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_ACCESS_KEY=your_secure_minio_access_key_here
MINIO_SECRET_KEY=your_secure_minio_secret_key_here

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here_must_be_at_least_64_bytes_base64_encoded
