{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{"color": "green","value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "文章总浏览量",
      "type": "stat",
      "targets": [{ "expr": "news_article_views_total", "legendFormat": "浏览量" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{"color": "blue","value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "用户登录总次数",
      "type": "stat",
      "targets": [{ "expr": "sum(news_user_login_total)", "legendFormat": "登录次数" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{"color": "purple","value": null}] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "发布文章总数",
      "type": "stat",
      "targets": [{ "expr": "news_headlines_published_total", "legendFormat": "发布数" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP 请求 QPS (按接口)",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (uri) (rate(http_server_requests_seconds_count{uri!~\".*(actuator|swagger).*\"}[1m]))", "legendFormat": "{{uri}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP P99 响应时间",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{uri!~\".*(actuator|swagger).*\"}[5m])))", "legendFormat": "P99 {{uri}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table" }, "tooltip": { "mode": "multi" } },
      "title": "JVM 堆内存使用",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "已使用 ({{id}})" },
        { "expr": "jvm_memory_max_bytes{area=\"heap\"}", "legendFormat": "最大容量 ({{id}})" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table" } },
      "title": "RSS 同步耗时 (P95)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(news_rss_sync_duration_seconds_bucket[30m])))", "legendFormat": "P95 同步耗时" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "id": 8,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table" } },
      "title": "登录次数 (按角色)",
      "type": "timeseries",
      "targets": [{ "expr": "news_user_login_total", "legendFormat": "{{role}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 9,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table" } },
      "title": "JVM 线程数",
      "type": "timeseries",
      "targets": [{ "expr": "jvm_threads_live_threads", "legendFormat": "活跃线程" }]
    }
  ],
  "schemaVersion": 38,
  "tags": ["news", "springboot", "java"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Shanghai",
  "title": "News_JavaWeb 全链路监控",
  "uid": "news-javaweb-v1",
  "version": 1
}
